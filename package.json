{
  "name": "flaxeo-ui",
  "version": "0.4.0",
  "description": "FlaxeoUI - AI Image Generation Studio using stable-diffusion.cpp (Vue + Electron)",
  "main": "./out/main/index.js",
  "author": "FlaxeoUI contributors",
  "homepage": "https://github.com/fabricio3g/FlaxeoUI",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "node --experimental-strip-types --test src/shared/*.test.ts",
    "start": "electron-vite preview -- --no-sandbox",
    "dev": "node build-server.js && electron-vite dev -- --no-sandbox",
    "build": "npm run typecheck && electron-vite build && node build-server.js",
    "postinstall": "electron-builder install-app-deps",
    "prebuild:win": "node create-folder-structure.js",
    "prebuild:linux": "node create-folder-structure.js",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run prebuild:win && npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run prebuild:linux && npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@lucide/vue": "^1.24.0",
    "@ngrok/ngrok": "^1.7.0",
    "@respeak/lucide-motion-vue": "^0.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vueuse/core": "^14.3.0",
    "adm-zip": "^0.5.16",
    "class-variance-authority": "^0.7.1",
    "cloudflared": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "lucide-vue-next": "^0.562.0",
    "motion-v": "^2.3.0",
    "multer": "^2.0.2",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tar": "^7.5.2",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
