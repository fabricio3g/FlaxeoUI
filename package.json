{
  "name": "flaxeo-ui",
  "version": "0.7.6",
  "description": "Flaxeo Image — local AI image studio using stable-diffusion.cpp (Vue + Electron)",
  "main": "./out/main/index.js",
  "author": "Flaxeo Image contributors",
  "homepage": "https://github.com/fabricio3g/FlaxeoUI",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "lint:ci": "eslint --cache . --max-warnings 0 --quiet",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "node --experimental-strip-types --test src/shared/*.test.ts",
    "start": "electron-vite preview -- --no-sandbox",
    "dev": "electron-vite build && node generate-renderer-manifest.mjs out/renderer && node build-server.js && electron-vite dev -- --no-sandbox",
    "build": "npm run typecheck && electron-vite build && node generate-renderer-manifest.mjs out/renderer && node build-server.js",
    "postinstall": "electron-builder install-app-deps",
    "prebuild:win": "node create-folder-structure.js",
    "prebuild:linux": "node create-folder-structure.js",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run prebuild:win && npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run prebuild:linux && npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@lucide/vue": "^1.24.0",
    "@respeak/lucide-motion-vue": "^0.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vueuse/core": "^14.3.0",
    "adm-zip": "^0.5.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "lucide-vue-next": "^0.562.0",
    "motion-v": "^2.3.0",
    "multer": "^2.2.0",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.10.1",
    "selfsigned": "^5.5.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tar": "^7.5.20",
    "uqr": "^0.1.3",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.19.1",
    "electron": "^41.10.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.6"
  }
}
